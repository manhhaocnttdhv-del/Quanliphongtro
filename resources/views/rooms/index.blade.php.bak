<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<script>
    $(document).ready(function() {
        // Location selection logic
        const provinceSelect = $('#province');
        const districtSelect = $('#district');
        const wardSelect = $('#ward');

        // Load provinces
        fetch('https://provinces.open-api.vn/api/p/')
            .then(response => response.json())
            .then(data => {
                const currentProvince = "{{ request('province') }}";
                data.forEach(p => {
                    const selected = (p.name === currentProvince) ? 'selected' : '';
                    provinceSelect.append(`<option value="${p.name}" data-code="${p.code}" ${selected}>${p.name}</option>`);
                });
                if (currentProvince) provinceSelect.trigger('change');
            });

        provinceSelect.on('change', function() {
            const code = $(this).find(':selected').data('code');
            districtSelect.empty().append('<option value="">Tất cả</option>').prop('disabled', true);
            if (code) {
                fetch(`https://provinces.open-api.vn/api/p/${code}?depth=2`)
                    .then(response => response.json())
                    .then(data => {
                        const currentDistrict = "{{ request('district') }}";
                        data.districts.forEach(d => {
                            const selected = (d.name === currentDistrict) ? 'selected' : '';
                            districtSelect.append(`<option value="${d.name}" data-code="${d.code}" ${selected}>${d.name}</option>`);
                        });
                        districtSelect.prop('disabled', false);
                        if (currentDistrict) districtSelect.trigger('change');
                    });
            }
        });

        districtSelect.on('change', function() {
            const code = $(this).find(':selected').data('code');
            wardSelect.empty().append('<option value="">Tất cả</option>').prop('disabled', true);
            if (code) {
                fetch(`https://provinces.open-api.vn/api/d/${code}?depth=2`)
                    .then(response => response.json())
                    .then(data => {
                        const currentWard = "{{ request('ward') }}";
                        data.wards.forEach(w => {
                            const selected = (w.name === currentWard) ? 'selected' : '';
                            wardSelect.append(`<option value="${w.name}" ${selected}>${w.name}</option>`);
                        });
                        wardSelect.prop('disabled', false);
                    });
            }
        });

        // Map logic
        let map;
        const rooms = @json($allRooms);
        
        $('#toggleMap').on('click', function() {
            $('#mapWrapper').toggleClass('d-none');
            $(this).toggleClass('btn-warning btn-outline-dark');
            
            if (!map && !$('#mapWrapper').hasClass('d-none')) {
                const center = rooms.length > 0 && rooms[0].latitude 
                    ? [rooms[0].latitude, rooms[0].longitude] 
                    : [10.762622, 106.660172];

                map = L.map('searchMap').setView(center, 12);
                
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
                }).addTo(map);

                rooms.forEach(room => {
                    if (room.latitude && room.longitude) {
                        const marker = L.marker([room.latitude, room.longitude]).addTo(map);
                        marker.bindPopup(`
                            <div class="p-2">
                                <h6 class="fw-bold mb-1">${room.name}</h6>
                                <p class="small text-muted mb-2">${room.address_detail}</p>
                                <div class="text-warning fw-bold mb-2">${new Intl.NumberFormat('vi-VN').format(room.price)}đ</div>
                                <a href="/rooms/${room.id}" class="btn btn-sm btn-primary w-100 text-white">Chi tiết</a>
                            </div>
                        `, { minWidth: 200 });
                    }
                });
            }
            if (map) {
                setTimeout(() => map.invalidateSize(), 100);
            }
        });
    });
</script>
@endsection
